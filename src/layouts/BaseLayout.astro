---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = SITE_DESCRIPTION, noindex = false } = Astro.props;
const fullTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="top-accent"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <a href="#top" class="back-to-top" aria-label="ページトップへ">↑</a>
    <script>
      // クーポン適用ボタンの2段階クリック制御
      // 1回目: 価格 reveal(全 clinic-compare を is-applied 状態に)
      // 2回目: 通常の遷移(DMM へ)
      document.addEventListener('DOMContentLoaded', () => {
        const compares = document.querySelectorAll('.clinic-compare');
        if (!compares.length) return;

        const STORAGE_KEY = 'glp-navi-coupon-applied';
        const applyButtons = document.querySelectorAll('.clinic-compare__apply');

        // URL に ?reset があれば sessionStorage クリア(検証用)
        try {
          const urlParams = new URLSearchParams(window.location.search);
          if (urlParams.has('reset')) {
            sessionStorage.removeItem(STORAGE_KEY);
            history.replaceState(null, '', window.location.pathname);
          }
        } catch (e) {}

        function applyAll() {
          compares.forEach((c) => c.classList.add('is-applied'));
          // テキスト切り替えは CSS の pre/post 表示制御で行うため不要
        }

        function resetAll() {
          compares.forEach((c) => c.classList.remove('is-applied'));
          try { sessionStorage.removeItem(STORAGE_KEY); } catch (err) {}
        }

        // 検証用リセットリンクを wire up
        document.querySelectorAll('[data-coupon-reset]').forEach((el) => {
          el.addEventListener('click', (e) => {
            e.preventDefault();
            resetAll();
          });
        });

        // セッション内で既に適用済みなら最初から表示
        try {
          if (sessionStorage.getItem(STORAGE_KEY) === '1') {
            applyAll();
          }
        } catch (e) {}

        applyButtons.forEach((link) => {
          link.addEventListener('click', (e) => {
            const alreadyApplied = link.closest('.clinic-compare').classList.contains('is-applied');
            if (!alreadyApplied) {
              e.preventDefault();
              applyAll();
              try {
                sessionStorage.setItem(STORAGE_KEY, '1');
              } catch (err) {}
            }
            // 適用済みなら通常遷移
          });
        });

        // 自動 reveal: アセットを「通り過ぎた」タイミングで applyAll
        // (一度 viewport に入ったあと、また外れた = スクロール過ぎ)
        if ('IntersectionObserver' in window) {
          const autoObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.dataset.scrollSeen = '1';
              } else if (entry.target.dataset.scrollSeen === '1') {
                const anyApplied = Array.from(compares).some((c) =>
                  c.classList.contains('is-applied')
                );
                if (!anyApplied) {
                  applyAll();
                  try {
                    sessionStorage.setItem(STORAGE_KEY, '1');
                  } catch (e) {}
                }
              }
            });
          }, { threshold: 0 });

          compares.forEach((c) => autoObserver.observe(c));
        }
      });
    </script>
  </body>
</html>
